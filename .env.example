# --- The CMS at /app ------------------------------------------------------
# Without both of these, /app is disabled and shows a "not set up" notice.
# The public site does not need them: it falls back to the wording in the code.

# Signs the session cookie. Generate with: openssl rand -hex 32
APP_SESSION_SECRET=

# The content database.
#   local        postgres://you@localhost:5432/jepegomi   (after: createdb jepegomi)
#   production   the Neon connection string
# The first visit to /app creates the tables and offers to create your account.
DATABASE_URL=

# --- Where uploaded photos are written -----------------------------------
# Leave these BLANK for local development: photos are written straight into
# public/photos/kitchen/ on disk.
#
# Set them in PRODUCTION. A serverless filesystem is read-only, so on the live
# site the tool commits photos into the repo instead. Needs a GitHub token with
# "Contents: read and write" on this repo.
GITHUB_TOKEN=
GITHUB_REPO=digitalbrushcreative/jepegomi
GITHUB_BRANCH=main
